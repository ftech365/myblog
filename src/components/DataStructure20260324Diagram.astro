---
// XmlImportDiagram.astro
// XMLファイル間のimport参照関係図
---

<div class="xml-diagram-wrap">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 680 360"
    width="100%"
    aria-label="XMLファイル間のimport参照関係図"
    role="img"
  >
    <defs>
      <marker id="arr" viewBox="0 0 10 10" refX="8" refY="5"
        markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M2 1L8 5L2 9" fill="none" stroke="currentColor"
          stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </marker>
      <marker id="arr-ref" viewBox="0 0 10 10" refX="8" refY="5"
        markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M2 1L8 5L2 9" fill="none" stroke="context-stroke"
          stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </marker>
    </defs>

    <!-- main-config.xml（起点） -->
    <g>
      <rect x="220" y="20" width="240" height="52" rx="8"
        fill="var(--xml-main-bg, #ede9fe)" stroke="var(--xml-main-stroke, #7c3aed)"
        stroke-width="1"/>
      <text x="340" y="42" text-anchor="middle"
        font-family="var(--font-mono, monospace)" font-size="13" font-weight="600"
        fill="var(--xml-main-text, #4c1d95)">main-config.xml</text>
      <text x="340" y="60" text-anchor="middle"
        font-family="var(--font-sans, sans-serif)" font-size="11"
        fill="var(--xml-main-sub, #6d28d9)">メインの設定ファイル</text>
    </g>

    <!-- import 矢印（main → 各ファイル） -->
    <line x1="280" y1="72" x2="120" y2="150"
      stroke="var(--xml-import-stroke, #6366f1)" stroke-width="1.5"
      stroke-dasharray="5 3" marker-end="url(#arr)"/>
    <line x1="340" y1="72" x2="340" y2="150"
      stroke="var(--xml-import-stroke, #6366f1)" stroke-width="1.5"
      stroke-dasharray="5 3" marker-end="url(#arr)"/>
    <line x1="400" y1="72" x2="560" y2="150"
      stroke="var(--xml-import-stroke, #6366f1)" stroke-width="1.5"
      stroke-dasharray="5 3" marker-end="url(#arr)"/>

    <!-- import ラベル -->
    <text x="186" y="118" text-anchor="middle"
      font-family="var(--font-sans, sans-serif)" font-size="10"
      fill="var(--xml-import-stroke, #6366f1)">import</text>
    <text x="354" y="118" text-anchor="middle"
      font-family="var(--font-sans, sans-serif)" font-size="10"
      fill="var(--xml-import-stroke, #6366f1)">import</text>
    <text x="494" y="118" text-anchor="middle"
      font-family="var(--font-sans, sans-serif)" font-size="10"
      fill="var(--xml-import-stroke, #6366f1)">import</text>

    <!-- database.xml -->
    <g>
      <rect x="40" y="150" width="160" height="52" rx="8"
        fill="var(--xml-sub-bg, #eff6ff)" stroke="var(--xml-sub-stroke, #3b82f6)"
        stroke-width="1"/>
      <text x="120" y="172" text-anchor="middle"
        font-family="var(--font-mono, monospace)" font-size="12" font-weight="600"
        fill="var(--xml-sub-text, #1e40af)">database.xml</text>
      <text x="120" y="190" text-anchor="middle"
        font-family="var(--font-sans, sans-serif)" font-size="11"
        fill="var(--xml-sub-sub, #3b82f6)">DB接続設定</text>
    </g>

    <!-- server.xml -->
    <g>
      <rect x="260" y="150" width="160" height="52" rx="8"
        fill="var(--xml-sub-bg, #eff6ff)" stroke="var(--xml-sub-stroke, #3b82f6)"
        stroke-width="1"/>
      <text x="340" y="172" text-anchor="middle"
        font-family="var(--font-mono, monospace)" font-size="12" font-weight="600"
        fill="var(--xml-sub-text, #1e40af)">server.xml</text>
      <text x="340" y="190" text-anchor="middle"
        font-family="var(--font-sans, sans-serif)" font-size="11"
        fill="var(--xml-sub-sub, #3b82f6)">サーバー設定</text>
    </g>

    <!-- logging.xml -->
    <g>
      <rect x="480" y="150" width="160" height="52" rx="8"
        fill="var(--xml-sub-bg, #eff6ff)" stroke="var(--xml-sub-stroke, #3b82f6)"
        stroke-width="1"/>
      <text x="560" y="172" text-anchor="middle"
        font-family="var(--font-mono, monospace)" font-size="12" font-weight="600"
        fill="var(--xml-sub-text, #1e40af)">logging.xml</text>
      <text x="560" y="190" text-anchor="middle"
        font-family="var(--font-sans, sans-serif)" font-size="11"
        fill="var(--xml-sub-sub, #3b82f6)">ログ設定</text>
    </g>

    <!-- 参照矢印（database・server → shared-schema.xsd） -->
    <line x1="120" y1="202" x2="240" y2="288"
      stroke="var(--xml-ref-stroke)" stroke-width="1.5"
      stroke-dasharray="4 3" marker-end="url(#arr-ref)"/>
    <line x1="340" y1="202" x2="300" y2="288"
      stroke="var(--xml-ref-stroke)" stroke-width="1.5"
      stroke-dasharray="4 3" marker-end="url(#arr-ref)"/>

    <!-- 参照ラベル -->
    <text x="160" y="258" text-anchor="middle"
      font-family="var(--font-sans, sans-serif)" font-size="10"
      fill="var(--xml-ref-stroke)">参照</text>
    <text x="344" y="258" text-anchor="middle"
      font-family="var(--font-sans, sans-serif)" font-size="10"
      fill="var(--xml-ref-stroke)">参照</text>

    <!-- shared-schema.xsd -->
    <g>
      <rect x="200" y="288" width="200" height="52" rx="8"
        fill="var(--xml-schema-bg)" stroke="var(--xml-schema-stroke)"
        stroke-width="1"/>
      <text x="300" y="310" text-anchor="middle"
        font-family="var(--font-mono, monospace)" font-size="12" font-weight="600"
        fill="var(--xml-schema-text)">shared-schema.xsd</text>
      <text x="300" y="328" text-anchor="middle"
        font-family="var(--font-sans, sans-serif)" font-size="11"
        fill="var(--xml-schema-sub)">共通の型定義ファイル</text>
    </g>

    <!-- 凡例 -->
    <line x1="40" y1="352" x2="72" y2="352"
      stroke="var(--xml-import-stroke, #6366f1)" stroke-width="1.5"
      stroke-dasharray="5 3" marker-end="url(#arr)"/>
    <text x="78" y="356" font-family="var(--font-sans, sans-serif)" font-size="11"
      fill="var(--xml-legend-text, #4b5563)">import（ファイルを読み込む）</text>

    <line x1="310" y1="352" x2="342" y2="352"
      stroke="var(--xml-ref-stroke)" stroke-width="1.5"
      stroke-dasharray="4 3" marker-end="url(#arr-ref)"/>
    <text x="348" y="356" font-family="var(--font-sans, sans-serif)" font-size="11"
      fill="var(--xml-legend-text, #4b5563)">参照（型定義を参照する）</text>
  </svg>
</div>

<style>
  .xml-diagram-wrap {
    margin: 1.5rem 0;
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 0.75rem;
    padding: 1rem;
    background: var(--color-surface, #ffffff);
    overflow-x: auto;

    /* ライトモードのデフォルト値 */
    --xml-main-bg: #ede9fe;
    --xml-main-stroke: #7c3aed;
    --xml-main-text: #4c1d95;
    --xml-main-sub: #6d28d9;
    --xml-import-stroke: #6366f1;
    --xml-sub-bg: #eff6ff;
    --xml-sub-stroke: #3b82f6;
    --xml-sub-text: #1e40af;
    --xml-sub-sub: #3b82f6;
    --xml-schema-bg: #fff7ed;
    --xml-schema-stroke: #e07b00;
    --xml-schema-text: #92400e;
    --xml-schema-sub: #e07b00;
    --xml-ref-stroke: #e07b00;
    --xml-legend-text: #4b5563;
  }

  /* クラスベースのダークモード（Tailwind dark: など） */
  :global(.dark) .xml-diagram-wrap,
  /* OSレベルのダークモード */
  @media (prefers-color-scheme: dark) {
    .xml-diagram-wrap {
      background: var(--color-surface, #1e1e2e);
      border-color: #374151;
      --xml-main-bg: #2e1065;
      --xml-main-stroke: #a78bfa;
      --xml-main-text: #ede9fe;
      --xml-main-sub: #c4b5fd;
      --xml-import-stroke: #818cf8;
      --xml-sub-bg: #1e3a5f;
      --xml-sub-stroke: #60a5fa;
      --xml-sub-text: #bfdbfe;
      --xml-sub-sub: #93c5fd;
      --xml-schema-bg: #431407;
      --xml-schema-stroke: #fb923c;
      --xml-schema-text: #fed7aa;
      --xml-schema-sub: #fb923c;
      --xml-ref-stroke: #fb923c;
      --xml-legend-text: #d1d5db;
    }
  }
</style>
